{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vaultghost.dev/schemas/proof_or_quarantine_event.schema.json",
  "title": "VaultGhost Proof-or-Quarantine Event",
  "description": "A conservative claim-classification event for LLM outputs. Separates claim bucket assignment from actual evidence resolution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "event_id",
    "created_at",
    "verifier",
    "input",
    "model_output",
    "claims",
    "classification_summary",
    "canonicalization",
    "event_integrity",
    "limitations",
    "classification_ruleset"
  ],
  "properties": {
    "schema_name": {
      "type": "string",
      "const": "vaultghost.proof_or_quarantine_event"
    },
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "event_id": {
      "type": "string",
      "description": "Unique event identifier. UUIDv7 preferred, UUIDv4 acceptable for demo use."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp."
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verifier_id",
        "verifier_version",
        "verification_method",
        "execution_mode"
      ],
      "properties": {
        "verifier_id": {
          "type": "string"
        },
        "verifier_version": {
          "type": "string"
        },
        "verification_method": {
          "type": "string",
          "enum": [
            "threshold_classification_only",
            "evidence_pointer_checked",
            "artifact_hash_bound",
            "independent_replay"
          ]
        },
        "execution_mode": {
          "type": "string",
          "enum": [
            "browser_demo",
            "local_cli",
            "ci_pipeline",
            "server_backend",
            "independent_auditor"
          ]
        }
      }
    },
    "classification_ruleset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleset_id",
        "ruleset_version",
        "ruleset_hash"
      ],
      "properties": {
        "ruleset_id": {
          "type": "string"
        },
        "ruleset_version": {
          "type": "string"
        },
        "ruleset_hash": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_hash",
        "prompt_disclosure"
      ],
      "properties": {
        "prompt_disclosure": {
          "type": "string",
          "enum": ["raw", "redacted", "hash_only"]
        },
        "prompt_text": {
          "type": "string"
        },
        "prompt_hash": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "source_context_refs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/source_ref"
          },
          "default": []
        }
      }
    },
    "model_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_answer",
        "answer_hash"
      ],
      "properties": {
        "raw_answer": {
          "type": "string"
        },
        "surviving_answer": {
          "type": "string"
        },
        "answer_hash": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "model_name": {
          "type": "string"
        },
        "model_provider": {
          "type": "string"
        }
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/claim"
      }
    },
    "classification_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_claims",
        "verified_count",
        "provisionally_verified_count",
        "inferred_count",
        "quarantined_count"
      ],
      "properties": {
        "total_claims": {
          "type": "integer",
          "minimum": 0
        },
        "verified_count": {
          "type": "integer",
          "minimum": 0
        },
        "provisionally_verified_count": {
          "type": "integer",
          "minimum": 0
        },
        "inferred_count": {
          "type": "integer",
          "minimum": 0
        },
        "quarantined_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "canonicalization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "hash_algorithm",
        "hash_excludes"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["RFC8785_JCS", "demo_sorted_json"]
        },
        "hash_algorithm": {
          "type": "string",
          "enum": ["SHA-256"]
        },
        "hash_excludes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "event_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_hash",
        "hash_scope"
      ],
      "properties": {
        "event_hash": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "hash_scope": {
          "type": "string",
          "enum": [
            "event_without_event_hash",
            "event_plus_resolved_evidence_hashes",
            "event_plus_replay_bundle"
          ]
        },
        "signature": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "algorithm",
            "public_key_id",
            "signature_value"
          ],
          "properties": {
            "algorithm": {
              "type": "string",
              "enum": ["Ed25519"]
            },
            "public_key_id": {
              "type": "string"
            },
            "signature_value": {
              "type": "string"
            }
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "ref_type"
      ],
      "properties": {
        "ref_id": {
          "type": "string"
        },
        "ref_type": {
          "type": "string",
          "enum": [
            "file",
            "url",
            "git_commit",
            "ci_log",
            "court_filing",
            "email",
            "manual_note",
            "other"
          ]
        },
        "uri_or_path": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "claim_text",
        "claim_type",
        "confidence",
        "claim_bucket",
        "evidence_status",
        "rationale",
        "risk_flags"
      ],
      "properties": {
        "claim_id": {
          "type": "string"
        },
        "claim_text": {
          "type": "string"
        },
        "claim_type": {
          "type": "string",
          "enum": [
            "factual",
            "technical",
            "causal",
            "intent",
            "legal",
            "procedural",
            "financial",
            "conclusion",
            "recommendation",
            "prediction",
            "value_judgment"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "claim_bucket": {
          "type": "string",
          "enum": [
            "verified",
            "provisionally_verified",
            "inferred",
            "quarantined"
          ]
        },
        "evidence_status": {
          "type": "string",
          "enum": [
            "none_provided",
            "self_reported_pointer_only",
            "pointer_format_valid",
            "artifact_resolved",
            "artifact_hash_bound",
            "independently_replayed"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/evidence_item"
          },
          "default": []
        },
        "rationale": {
          "type": "string"
        },
        "risk_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "unsupported_factual_claim",
              "weak_evidence_type",
              "intent_claim",
              "legal_conclusion",
              "causal_overclaim",
              "technical_claim_requires_byte_level_check",
              "financial_exposure",
              "destructive_action",
              "sensitive_data",
              "ambiguous_scope",
              "contradicted_by_evidence"
            ]
          }
        },
        "required_upgrade_for_verification": {
          "type": "string"
        }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "evidence_type",
        "evidence_pointer",
        "evidence_quality",
        "resolver_status"
      ],
      "properties": {
        "evidence_id": {
          "type": "string"
        },
        "evidence_type": {
          "type": "string",
          "enum": [
            "none",
            "model_asserted_pointer",
            "visual_ui",
            "file_view",
            "log_excerpt",
            "full_command_output",
            "hashed_artifact",
            "git_blob",
            "ci_run",
            "court_record",
            "signed_manifest",
            "independent_replay"
          ]
        },
        "evidence_pointer": {
          "type": "string"
        },
        "evidence_quality": {
          "type": "string",
          "enum": [
            "none",
            "weak",
            "moderate",
            "strong",
            "forensic"
          ]
        },
        "resolver_status": {
          "type": "string",
          "enum": [
            "not_attempted",
            "failed",
            "resolved",
            "resolved_and_hashed",
            "replayed"
          ]
        },
        "artifact_hash": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "resolver_notes": {
          "type": "string"
        }
      }
    }
  }
}